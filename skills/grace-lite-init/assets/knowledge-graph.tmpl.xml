<?xml version="1.0" encoding="utf-8"?>
<!--
  GRACE-lite Knowledge Graph Template
  ====================================
  This file is the navigational code graph for the project.
  See AGENTS.md (GRACE-lite section) for full rules.

  RULES (quick reference):
  ─────────────────────────
  1. Root element MUST be <KnowledgeGraph>.
  2. Single <Project NAME="..." VERSION="..."> child.
  3. Module entries use M-<DOMAIN> as the XML tag (never generic <Module>).
     TYPE ∈ { ENTRY_POINT, CORE_LOGIC, DATA_LAYER, UI_COMPONENT, UTILITY, INTEGRATION }
     STATUS ∈ { planned, partial, implemented }
  4. Every module MUST have: <purpose>, <path>, <depends>.
  5. Annotation tags inside <annotations> use prefixes:
     fn-, class-, type-, export-, const-
     Each annotation MUST have a PURPOSE attribute.
  6. Data flow entries use DF-<NAME> as the XML tag with a NAME attribute.
     Flow text: M-IDs joined by ->  (sequential)
                ;  (parallel/independent paths)
                /  (alternative modules within one step)
  7. Cross-module links use <CrossLink from="M-X" to="M-Y" relation="..." />.
     All from/to values MUST reference existing M-IDs.
  8. <depends> values referencing M-IDs MUST be existing module tags.
  9. <path> values SHOULD point to real files relative to the project root.
  10. Keywords and annotations are concise navigation hints — do NOT duplicate
      OpenSpec requirements here.
  11. Private helper details do NOT belong in this graph — only module
      boundaries, public interfaces, and stable navigation anchors.
-->
<KnowledgeGraph>
  <Project NAME="project-name" VERSION="0.0.0">
    <keywords>keyword1, keyword2</keywords>
    <annotation>One-line project description.</annotation>

    <!--
      Module entries
      ──────────────
      Each governed module gets a unique M-ID tag.
      Example:
    -->
    <M-EXAMPLE NAME="Example module" TYPE="CORE_LOGIC" STATUS="planned">
      <purpose>One-line purpose description of this module.</purpose>
      <path>src/example/module.py</path>
      <depends>none</depends>
      <annotations>
        <fn-do_work PURPOSE="Main entry point for the work" />
        <class-WorkResult PURPOSE="Result shape returned by do_work" />
        <type-WorkConfig PURPOSE="Configuration for work parameters" />
        <export-work PURPOSE="Public module export" />
        <const-MAX_RETRIES PURPOSE="Maximum retry attempts" />
      </annotations>
    </M-EXAMPLE>

    <!--
      Another module that depends on the first:
    -->
    <M-API NAME="API layer" TYPE="ENTRY_POINT" STATUS="planned">
      <purpose>HTTP API routes and request handling.</purpose>
      <path>src/example/api.py</path>
      <depends>M-EXAMPLE</depends>
      <annotations>
        <fn-handle_request PURPOSE="Process incoming HTTP request" />
      </annotations>
    </M-API>

    <!--
      Data flows
      ──────────
      Show execution paths through modules.
      -> sequential, ; parallel, / alternative
    -->
    <DF-PROCESS NAME="Process request">M-API -> M-EXAMPLE</DF-PROCESS>
    <DF-STREAM NAME="Parallel streams">M-API -> M-EXAMPLE; M-API -> M-LOGGING</DF-STREAM>

    <!--
      Cross-module links
      ──────────────────
      Semantic relationships beyond direct dependency.
    -->
    <CrossLink from="M-API" to="M-EXAMPLE" relation="delegates core processing" />
    <CrossLink from="M-EXAMPLE" to="M-LOGGING" relation="emits structured markers" />

  </Project>
</KnowledgeGraph>
